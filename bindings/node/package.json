{
  "name": "warpsock",
  "version": "4.2.6",
  "description": "Node.js bindings for Warpsock, a browser-fingerprint HTTP client with TLS, HTTP/1.1, HTTP/2, HTTP/3, and WebSocket support. Improved TTFT and TPS for LLMs.",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "warpsock",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "napi build --platform --release --dts index.gen.d.ts",
    "build:debug": "napi build --platform",
    "create:npm-dirs": "napi create-npm-dirs",
    "prepublishOnly": "napi prepublish -t npm --no-gh-release",
    "artifacts": "napi artifacts --output-dir ./artifacts",
    "test": "jest"
  },
  "jest": {
    "testMatch": [
      "**/__tests__/*.test.js"
    ],
    "testTimeout": 60000
  },
  "optionalDependencies": {
    "warpsock-darwin-x64": "4.2.6",
    "warpsock-darwin-arm64": "4.2.6",
    "warpsock-linux-x64-gnu": "4.2.6",
    "warpsock-linux-arm64-gnu": "4.2.6"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.6.2",
    "jest": "^29.7.0"
  },
  "keywords": [
    "http",
    "http2",
    "http3",
    "tls",
    "fingerprint",
    "chrome",
    "browser",
    "impersonate",
    "websocket",
    "client",
    "async",
    "native",
    "scraping",
    "llm",
    "streaming",
    "sse",
    "ttfb"
  ],
  "author": "Jared Boynton",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jaredboynton/warpsock.git",
    "directory": "bindings/node"
  }
}
